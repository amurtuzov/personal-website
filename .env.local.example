# Local development (MinIO + local Postgres)
NODE_ENV=development
PORT=4000

# Database (Docker Compose postgres service)
DATABASE_URL="postgresql://postgres:test_password_123@postgres:5432/photosdb?schema=public"
POSTGRES_PASSWORD=test_password_123

# Redis (Docker Compose redis service)
REDIS_URL=redis://redis:6379
# Required: password for Redis auth (used by backend/workers and Redis container)
REDIS_PASSWORD=your_redis_password

# JWT
JWT_SECRET=change-me-local-secret-please

# S3 via MinIO (Docker Compose override)
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
S3_ENDPOINT=http://minio:9000
# Public endpoint used for presigned upload URLs (browser needs a host-reachable address)
S3_PRESIGN_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=amurtuzov-photos
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
# Optional CDN/public URL (leave empty to use signed URLs)
# S3_PUBLIC_URL=localhost:9000

# Frontend (CMS) API endpoint baked at build time
VITE_API_URL=http://localhost:4000
# Frontend (Main Nuxt app) API endpoint baked at build time
NUXT_PUBLIC_API_URL=http://localhost:4000

# CMS basic auth for Caddy (optional for local reverse proxy)
CMS_BASIC_USER=your_cms_user
CMS_BASIC_PASS=your_secure_cms_password

# Contact form email (Google SMTP / Gmail app password)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=your_gmail_or_workspace_account@gmail.com
SMTP_PASS=your_app_password
CONTACT_TO=you@yourdomain.com
# For Gmail, this should usually be the same as SMTP_USER
CONTACT_FROM=your_gmail_or_workspace_account@gmail.com
CONTACT_SUBJECT_PREFIX=[Contact Form]

# Telegram Ops Bot (optional)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_ALLOWED_USER_IDS=123456789
# Optional: restrict to specific chat IDs (comma-separated)
# TELEGRAM_ALLOWED_CHAT_IDS=123456789
# Optional: override service allowlist for /logs /restart /recreate
# OPS_BOT_ALLOWED_SERVICES=backend,cleanup-worker,email-worker,image-worker,redis,postgres,minio,migrate
