generator client {
  provider            = "prisma-client-js"
  engine              = "binary"
  engineBinaryTargets = ["native", "linux-musl-arm64-openssl-1.1.x", "linux-arm64-openssl-1.1.x"]
  output              = "../generated/client"
}

datasource db {
  provider = "postgresql"
  // URL is now defined in prisma.config.ts at project root
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  name      String?
  createdAt DateTime @default(now())
}

model Album {
  id           String   @id @default(uuid())
  slug         String   @unique
  title        String
  description  String?
  isPublic     Boolean  @default(true)
  coverPhotoId String?
  photos       Photo[]
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Photo {
  id           String    @id @default(uuid())
  albumId      String?
  album        Album?    @relation(fields: [albumId], references: [id], onDelete: Cascade)
  userId       String?
  title        String?
  description  String?
  locationName String?
  takenAt      DateTime?
  s3Key        String    @db.Text
  webKey       String?   @db.Text
  thumbKey     String?   @db.Text
  width        Int?
  height       Int?
  exif         Json?
  isPublic     Boolean   @default(true)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

model Job {
  id          Int       @id @default(autoincrement())
  type        String
  payload     Json
  attempts    Int       @default(0)
  lockedUntil DateTime?
  createdAt   DateTime  @default(now())
}
