# Production (DigitalOcean Spaces + production Postgres)
NODE_ENV=production
PORT=4000

# CI/CD image source (used by docker-compose.prod.yml)
IMAGE_REGISTRY=ghcr.io
IMAGE_NAMESPACE=amurtuzov
# Deploy script can override this with IMAGE_TAG=<git-sha>
IMAGE_TAG=main

# Database
DATABASE_URL="postgresql://postgres:your_secure_password@your-db-host:5432/photosdb?schema=public"
POSTGRES_PASSWORD=your_secure_password

# Redis
REDIS_URL=redis://your-redis-host:6379
# Required: Redis auth password (can be in REDIS_URL and/or passed separately)
REDIS_PASSWORD=your_redis_password

# JWT
JWT_SECRET=replace_with_strong_random_secret_min_32_chars

# DigitalOcean Spaces
S3_ENDPOINT=https://nyc3.digitaloceanspaces.com
# Optional: override endpoint used for presigned upload URLs (usually not needed in production)
# S3_PRESIGN_ENDPOINT=https://nyc3.digitaloceanspaces.com
S3_REGION=nyc3
S3_BUCKET=your-bucket-name
S3_ACCESS_KEY_ID=your_spaces_key
S3_SECRET_ACCESS_KEY=your_spaces_secret
# Optional CDN/public URL (leave empty to use the Spaces URL)
S3_PUBLIC_URL=cdn.yourdomain.com

# Database backups (keep 2 dumps: latest + previous)
DB_BACKUP_LOCAL_DIR=/opt/personal-website/backups/db
DB_BACKUP_POSTGRES_DB=photosdb
DB_BACKUP_POSTGRES_USER=postgres
DB_BACKUP_SPACES_ENABLED=true
DB_BACKUP_SPACES_BUCKET=your-backup-bucket-or-same-bucket
DB_BACKUP_SPACES_REGION=nyc3
DB_BACKUP_SPACES_ENDPOINT=https://nyc3.digitaloceanspaces.com
DB_BACKUP_SPACES_PREFIX=db-backups/postgres
# Optional: dedicated backup keypair (falls back to S3_ACCESS_KEY_ID / S3_SECRET_ACCESS_KEY)
# DB_BACKUP_SPACES_ACCESS_KEY_ID=your_backup_key
# DB_BACKUP_SPACES_SECRET_ACCESS_KEY=your_backup_secret

# Frontend (CMS) API endpoint baked at build time
VITE_API_URL=https://api.yourdomain.com
# Frontend (Nuxt apps) API endpoint
NUXT_PUBLIC_API_URL=https://api.yourdomain.com
# Frontend (Photos Nuxt app) canonical base URL
NUXT_PUBLIC_BASE_URL=https://photos.yourdomain.com

# Backend CORS and form protection
CORS_ALLOWED_ORIGINS=https://amurtuzov.com,https://photos.amurtuzov.com,https://cms.amurtuzov.com
FORM_ALLOWED_ORIGINS=https://amurtuzov.com,https://photos.amurtuzov.com
FORM_MIN_SUBMISSION_MS=2000
FORM_MAX_SUBMISSION_MS=43200000

# CMS basic auth for Caddy
CMS_BASIC_USER=your_cms_user
# Local-only convenience value (plain password). Keep this file off git.
CMS_BASIC_PASS_PLAIN=your_secure_cms_password
# Must be a bcrypt hash generated via:
# BCRYPT_COST=12 ./scripts/set-cms-password.sh .env.production
# ./scripts/set-cms-password.sh .env.production
# Script stores Docker Compose-safe escaped value ($$2b$$...).
CMS_BASIC_PASS=replace_with_caddy_bcrypt_hash_compose_escaped

# Contact form email (Google SMTP / Gmail app password)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=your_gmail_or_workspace_account@gmail.com
SMTP_PASS=your_app_password
CONTACT_TO=you@yourdomain.com
# For Gmail, this should usually be the same as SMTP_USER
CONTACT_FROM=your_gmail_or_workspace_account@gmail.com
CONTACT_SUBJECT_PREFIX=[Contact Form]

# Telegram Ops Bot (optional)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_ALLOWED_USER_IDS=123456789
# Optional: restrict to specific chat IDs (comma-separated)
# TELEGRAM_ALLOWED_CHAT_IDS=123456789
# Optional: override service allowlist for /logs /restart /recreate
# OPS_BOT_ALLOWED_SERVICES=backend,cleanup-worker,email-worker,image-worker,redis,postgres,minio,migrate,main,photos,cms,caddy,ops-bot
