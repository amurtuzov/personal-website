    "pinia": "^3.0.4",
    "primeflex": "^4.0.0",
    "primeicons": "^7.0.0",
    "primevue": "^4.5.3",
    "vue": "^3.5.30",
    "vue-router": "^4.2.4",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^6.7.1",
    "@packages/database": "*",
    "@pinia/testing": "^1.0.3",
    "@types/node": "^22.10.1",
    "@vitejs/plugin-vue": "^6.0.3",
    "@vue/test-utils": "^2.4.1",
