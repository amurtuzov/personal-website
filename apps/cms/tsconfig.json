{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "strict": true,
    "jsx": "preserve",
    "moduleResolution": "bundler",
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "useDefineForClassFields": true,
    "baseUrl": ".",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "types": [
      "vite-svg-loader",
      "vite/client",
      "vitest/globals",
      "node",
    ],
    "paths": {
      "@/*": ["src/*"]
    }
  },
  "include": [
    "vite.config.*",
    "src/**/*.ts",
    "src/**/*.tsx",
    "src/**/*.vue",
    "tests/**/*.ts",
    "tests/**/*.tsx"
  ],
  "exclude": [
    "node_modules"
  ]
}
